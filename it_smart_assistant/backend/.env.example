# it_smart_assistant Environment Variables

# === Project ===
PROJECT_NAME=it_smart_assistant
DEBUG=true
ENVIRONMENT=local

# === Logfire ===
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=it_smart_assistant
LOGFIRE_ENVIRONMENT=development

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=it_smart_assistant

# === JWT Auth ===
SECRET_KEY=change-me-with-a-random-64-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === S3/MinIO Storage ===
STORAGE_BACKEND=filesystem
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=it-smart-assistant
S3_REGION=us-east-1
S3_SECURE=false

# === Retrieval / Embeddings ===
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=32
ENABLE_VECTOR_SEARCH=true
VECTOR_SEARCH_CANDIDATES=12
HYBRID_LEXICAL_WEIGHT=1.0
HYBRID_VECTOR_WEIGHT=60.0
ENABLE_OCR=false

# === Worker ===
WORKER_HEARTBEAT_SECONDS=30

# === AI Agent ===
LLM_PROVIDER=openai
OPENAI_API_KEY=
GOOGLE_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7

# === CORS ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
